# ── API access (BFF / same-origin proxy) ─────────────────────────────────────
# Recommended: leave NEXT_PUBLIC_API_BASE_URL UNSET so the client calls the API
# same-origin (/api/v1/*). Next.js then proxies /api/* to API_PROXY_TARGET. This
# keeps the HttpOnly session cookie first-party, so login works on mobile
# (cross-site cookies are blocked by Safari/Chrome on mobile).
# (unset == empty: the code falls back to a relative base either way)
# NEXT_PUBLIC_API_BASE_URL=

# Backend origin the proxy forwards to (server-only, never exposed to the client).
#   dev:  http://localhost:8080
#   prod: your backend URL, e.g. https://<your-backend>.onrender.com
API_PROXY_TARGET=http://localhost:8080

# Optional client overrides (defaults: api / v1 / 30000)
# NEXT_PUBLIC_API_PREFIX=api
# NEXT_PUBLIC_API_VERSION=v1
# NEXT_PUBLIC_API_TIMEOUT=30000
# NEXT_PUBLIC_ENABLE_API_LOGS=false

# Advanced: to call the backend DIRECTLY cross-origin instead of via the proxy,
# set NEXT_PUBLIC_API_BASE_URL to the absolute backend origin. Not recommended in
# prod — the session cookie becomes cross-site and is dropped on mobile.

# Optional Clerk demo (leave empty to show the setup notice under /clerk)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
