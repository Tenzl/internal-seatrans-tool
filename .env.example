# Backend API base origin (no trailing /api). The client appends /api/v1.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# Optional overrides (defaults: api / v1 / 30000)
# NEXT_PUBLIC_API_PREFIX=api
# NEXT_PUBLIC_API_VERSION=v1
# NEXT_PUBLIC_API_TIMEOUT=30000
# NEXT_PUBLIC_ENABLE_API_LOGS=false

# Dev-only proxy target for /api/* rewrites (see next.config.mjs)
API_PROXY_TARGET=http://localhost:8080

# Optional Clerk demo (leave empty to show the setup notice under /clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
